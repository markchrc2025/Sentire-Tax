# Supabase backend ("cloud" mode). Leave BOTH unset to use the local
# browser-storage store (no login). Set both to enable cloud mode: login,
# per-user data via Row-Level Security, and COR file uploads.
#
# In Vercel: Project → Settings → Environment Variables (Production + Preview).
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# --- Accounting Firm Portal connector (server/, optional) -------------------
# Set on the API service (server/), NOT the browser. When all three are present
# the "Import from Portal" flow appears and the server brokers OAuth2
# client-credentials calls to the Portal. PORTAL_BASE_URL includes /api/v1.
# PORTAL_BASE_URL=https://accounting-firm-portal.sliplane.app/api/v1
# PORTAL_CLIENT_ID=bir-generator
# PORTAL_CLIENT_SECRET=the-secret-set-on-the-portal-integration-client
